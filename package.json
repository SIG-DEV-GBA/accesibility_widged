{
  "name": "fpvsi-a11y-widget",
  "version": "1.0.2",
  "description": "Accessible widget with TTS reader, visual settings and language switcher",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.300"
  },
  "devDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.474.0",
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "widget",
    "tts",
    "text-to-speech",
    "react",
    "wcag"
  ],
  "author": "SIG-DEV-GBA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SIG-DEV-GBA/accesibility_widged.git"
  }
}
